<view class="page">
  <view class="section">
    <text class="title">我的活动</text>
    <button class="button-primary" bindtap="login">微信登录</button>
  </view>

  <view wx:for="{{activities}}" wx:key="member.id" class="card mine-card" bindtap="openDetail" data-id="{{item.activity.id}}">
    <view>
      <text class="role">{{item.member.role}}</text>
      <text class="activity-title">{{item.activity.title}}</text>
      <text class="muted">{{item.activity.startTimeText}} - {{item.activity.endTimeText}}</text>
    </view>
  </view>

  <view wx:if="{{!activities.length}}" class="section muted">暂无报名或发布的活动</view>
</view>
