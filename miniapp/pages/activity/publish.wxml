<view class="page">
  <view class="section">
    <label class="field">
      <text>活动标题</text>
      <input value="{{form.title}}" data-field="title" bindinput="onInput" />
    </label>
    <label class="field">
      <text>活动日期</text>
      <picker mode="date" data-field="startDate" bindchange="onDateChange">
        <view class="picker">{{form.startDate || '选择开始日期'}}</view>
      </picker>
    </label>
    <label class="field">
      <text>结束日期</text>
      <picker mode="date" data-field="endDate" bindchange="onDateChange">
        <view class="picker">{{form.endDate || '选择结束日期'}}</view>
      </picker>
    </label>
    <label class="field">
      <text>简介</text>
      <textarea value="{{form.summary}}" data-field="summary" bindinput="onInput" />
    </label>
    <label class="field">
      <text>行程安排</text>
      <textarea value="{{form.itinerary}}" data-field="itinerary" bindinput="onInput" />
    </label>
    <label class="field">
      <text>报名要求</text>
      <textarea value="{{form.requirements}}" data-field="requirements" bindinput="onInput" />
    </label>
    <label class="field">
      <text>注意事项</text>
      <textarea value="{{form.safetyNotes}}" data-field="safetyNotes" bindinput="onInput" />
    </label>
    <button class="button-ghost" bindtap="chooseCover">上传封面</button>
    <image wx:if="{{form.coverUrl}}" class="preview" src="{{form.coverUrl}}" mode="aspectFill" />
    <button class="button-ghost" bindtap="chooseQr">上传活动临时群二维码</button>
    <image wx:if="{{form.tempGroupQrUrl}}" class="qr" src="{{form.tempGroupQrUrl}}" mode="aspectFill" />
    <button class="button-primary" bindtap="submit">发布活动</button>
  </view>
</view>
