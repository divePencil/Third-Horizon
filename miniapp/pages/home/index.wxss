.hero {
  background: #173936;
  border-radius: 20rpx;
  color: #fff;
  display: grid;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 34rpx 28rpx;
}

.eyebrow {
  color: #b8d8d2;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
}

.subtitle {
  color: #d8eee8;
  font-size: 26rpx;
}

.activity-card image {
  height: 320rpx;
  width: 100%;
}

.activity-body {
  display: grid;
  gap: 10rpx;
  padding: 22rpx;
}

.activity-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.id,
.status {
  background: #e7f0ee;
  border-radius: 999rpx;
  color: #0d5c63;
  font-size: 22rpx;
  font-weight: 800;
  padding: 6rpx 12rpx;
}

.activity-title {
  font-size: 34rpx;
  font-weight: 900;
}

.summary {
  color: #405956;
  font-size: 26rpx;
  line-height: 1.6;
}
