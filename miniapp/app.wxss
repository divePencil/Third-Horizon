page {
  background: #f4f8f6;
  color: #173936;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 30rpx rgba(18, 51, 48, 0.08);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.muted {
  color: #60706d;
}

.button-primary {
  background: #0d5c63;
  border-radius: 999rpx;
  color: #fff;
  font-weight: 700;
}

.button-ghost {
  background: #e7f0ee;
  border-radius: 999rpx;
  color: #173936;
  font-weight: 700;
}

.field {
  display: block;
  margin-bottom: 20rpx;
}

.field text {
  color: #60706d;
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

input,
textarea {
  background: #f6faf8;
  border: 1rpx solid #d7e3df;
  border-radius: 12rpx;
  box-sizing: border-box;
  min-height: 76rpx;
  padding: 16rpx;
  width: 100%;
}

textarea {
  min-height: 160rpx;
}
